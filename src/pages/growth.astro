---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCompanies, getHistoricalSnapshots, getJobs, getMarketStats, getTickerItems, getTrackerSources } from "../lib/data";
import { countAddedThisWeek, enrichJobs } from "../lib/filters";
import { stageLabel } from "../lib/format";

type WeekPoint = {
  key: string;
  label: string;
  value: number;
};

type Comparison = {
  baseline: number;
  change: number;
  source: "snapshot" | "listing_date";
};

const companies = getCompanies();
const jobs = getJobs();
const liveJobs = enrichJobs(jobs, companies);
const tickerItems = getTickerItems();
const marketStats = getMarketStats();
const history = getHistoricalSnapshots();
const trackerSources = getTrackerSources();
const addedThisWeek = countAddedThisWeek(jobs);

function weekStart(date: Date) {
  const start = new Date(Date.UTC(date.getUTCFullYear(), date.getUTCMonth(), date.getUTCDate()));
  const day = start.getUTCDay() || 7;
  start.setUTCDate(start.getUTCDate() - day + 1);
  return start;
}

function weekKey(date: Date) {
  return weekStart(date).toISOString().slice(0, 10);
}

function formatWeek(key: string) {
  return new Intl.DateTimeFormat("en", { day: "2-digit", month: "short" }).format(new Date(`${key}T00:00:00.000Z`));
}

function differenceLabel(change: number, window: "WoW" | "MoM") {
  return `${change > 0 ? "+" : ""}${change} ${window}`;
}

function changeClass(change: number | null) {
  if (change === null) {
    return "neutral";
  }
  if (change === 0) {
    return "neutral";
  }
  return change > 0 ? "positive" : "negative";
}

const weeklyCounts = new Map<string, number>();

for (const job of liveJobs) {
  const key = weekKey(new Date(job.posted_at));
  weeklyCounts.set(key, (weeklyCounts.get(key) ?? 0) + 1);
}

const latestObservedKey = [...weeklyCounts.entries()]
  .filter(([, value]) => value > 0)
  .sort(([a], [b]) => b.localeCompare(a))[0]?.[0] ?? weekKey(new Date());
const latestWeekStart = new Date(`${latestObservedKey}T00:00:00.000Z`);
const weeks: WeekPoint[] = Array.from({ length: 26 }, (_, index) => {
  const date = new Date(latestWeekStart);
  date.setUTCDate(date.getUTCDate() - (25 - index) * 7);
  const key = date.toISOString().slice(0, 10);
  return {
    key,
    label: formatWeek(key),
    value: weeklyCounts.get(key) ?? 0
  };
});

const currentLiveRoles = liveJobs.length;

function comparisonTarget(daysAgo: number) {
  const target = new Date();
  target.setUTCDate(target.getUTCDate() - daysAgo);
  return target;
}

function snapshotAtOrBefore(daysAgo: number) {
  const target = comparisonTarget(daysAgo);

  return history
    .filter((snapshot) => new Date(snapshot.date).getTime() <= target.getTime())
    .at(-1) ?? null;
}

function listingDateBaseline(daysAgo: number) {
  const target = comparisonTarget(daysAgo).getTime();
  return liveJobs.filter((job) => new Date(job.posted_at).getTime() <= target).length;
}

function comparisonFor(daysAgo: number): Comparison {
  const snapshot = snapshotAtOrBefore(daysAgo);

  if (snapshot) {
    return {
      baseline: snapshot.live_role_count,
      change: currentLiveRoles - snapshot.live_role_count,
      source: "snapshot"
    };
  }

  const baseline = listingDateBaseline(daysAgo);
  return {
    baseline,
    change: currentLiveRoles - baseline,
    source: "listing_date"
  };
}

const wowComparison = comparisonFor(7);
const momComparison = comparisonFor(30);
const coreMetric = currentLiveRoles;
const maxWeekly = Math.max(...weeks.map((point) => point.value), 1);
const peakWeek = weeks.reduce((peak, point) => point.value > peak.value ? point : peak, weeks[0]);

function comparisonText(comparison: Comparison, window: "WoW" | "MoM") {
  return `${differenceLabel(comparison.change, window)} · from ${comparison.baseline}`;
}

function comparisonTitle(comparison: Comparison, window: "WoW" | "MoM") {
  if (comparison.source === "snapshot") {
    return `${window} comparison uses a stored historical snapshot.`;
  }

  return `${window} comparison uses listing dates because the tracker does not yet have an older stored snapshot for this window.`;
}

function countBy(values: string[]) {
  const counts = new Map<string, number>();
  for (const value of values) {
    counts.set(value, (counts.get(value) ?? 0) + 1);
  }

  return Array.from(counts.entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
}

function topRows(rows: Array<[string, number]>, limit: number, alwaysInclude: string[] = []) {
  const selected = rows.slice(0, limit);
  const required = alwaysInclude
    .filter((label) => !selected.some(([rowLabel]) => rowLabel === label))
    .map((label) => rows.find(([rowLabel]) => rowLabel === label))
    .filter((row): row is [string, number] => Boolean(row));

  if (required.length === 0) {
    return selected;
  }

  return [
    ...selected.slice(0, Math.max(0, limit - required.length)),
    ...required
  ].slice(0, limit);
}

function seniority(title: string) {
  const value = title.toLowerCase();
  if (/(director|head|manager|lead)/.test(value)) {
    return "Leadership";
  }
  if (/(principal|staff|senior|sr\.?)/.test(value)) {
    return "Senior IC";
  }
  if (/(junior|associate|graduate|intern)/.test(value)) {
    return "Early career";
  }
  return "Mid-level / unspecified";
}

const breakdowns = [
  {
    title: "Roles by company",
    rows: topRows(countBy(liveJobs.map((job) => job.company.name)), 10, ["Google Cloud"])
  },
  {
    title: "Roles by industry",
    rows: topRows(countBy(liveJobs.flatMap((job) => job.company.industry_tags)), 10, ["big tech / cloud", "genai / applied ai"])
  },
  {
    title: "Roles by country",
    rows: countBy(liveJobs.flatMap((job) => job.countries)).slice(0, 10)
  },
  {
    title: "Roles by seniority",
    rows: countBy(liveJobs.map((job) => seniority(job.title)))
  },
  {
    title: "Roles by remote / hybrid / onsite",
    rows: countBy(liveJobs.map((job) => job.location_type[0].toUpperCase() + job.location_type.slice(1)))
  },
  {
    title: "Roles by funding stage",
    rows: countBy(liveJobs.map((job) => stageLabel(job.company.stage)))
  }
];

const trackedCompanyNames = trackerSources.map((source) => source.company_name).join(", ");
const lastSourceRefresh = trackerSources
  .map((source) => source.observed_at)
  .sort()
  .at(-1);
---

<BaseLayout
  title="FDE Growth Tracker · FDE Jobs"
  description="A weekly tracker for the rise of Forward Deployed Engineer job volume by country, company, and industry."
  tickerItems={tickerItems}
  openRoleCount={liveJobs.length}
  addedThisWeek={addedThisWeek}
  marketStats={marketStats}
>
  <main class="site-shell">
    <section class="page-head page-head-narrow">
      <div class="eyebrow">Growth tracker</div>
      <h1 class="page-title">the rise of the FDE</h1>
      <p class="page-subhead">FDE job volume by country, company and industry</p>
    </section>

    <section class="growth-core" aria-label="Core FDE growth metric">
      <div>
        <span class="eyebrow">Core metric</span>
        <strong>{coreMetric}</strong>
        <p>
          Current live FDE roles tracked across multiple sites
        </p>
      </div>
      <div class="growth-change-stack">
        <span class={`metric-change ${changeClass(wowComparison.change)}`} title={comparisonTitle(wowComparison, "WoW")}>{comparisonText(wowComparison, "WoW")}</span>
        <span class={`metric-change ${changeClass(momComparison.change)}`} title={comparisonTitle(momComparison, "MoM")}>{comparisonText(momComparison, "MoM")}</span>
      </div>
    </section>

    <section class="timeseries-panel" aria-label="Weekly FDE role volume">
      <div class="chart-heading">
        <div>
          <span class="eyebrow">Weekly role volume</span>
          <h2>Number of FDE-related roles by week</h2>
        </div>
        <span class="mono micro">Peak {peakWeek.value} · Week of {peakWeek.label}</span>
      </div>
      <div class="week-chart">
        {weeks.map((point) => (
          <div class="week-bar" style={`--bar:${Math.max(4, Math.round((point.value / maxWeekly) * 100))}%`}>
            <span>{point.value}</span>
            <div aria-hidden="true"><span></span></div>
            <strong>{point.label}</strong>
          </div>
        ))}
      </div>
    </section>

    <section class="chart-grid" aria-label="FDE role breakdowns">
      {breakdowns.map((breakdown) => {
        const max = Math.max(...breakdown.rows.map(([, value]) => value), 1);
        return (
          <section class="chart-panel">
            <h2>{breakdown.title}</h2>
            <div class="bar-chart">
              {breakdown.rows.map(([label, value]) => (
                <div class="bar-row" style={`--bar:${Math.max(4, Math.round((value / max) * 100))}%`}>
                  <span>{label}</span>
                  <div aria-hidden="true"><span></span></div>
                  <strong>{value}</strong>
                </div>
              ))}
            </div>
          </section>
        );
      })}
    </section>

    <section class="source-note">
      <h2>Methodology</h2>
      <p>Source: Indeed Jobs "forward deployed engineer" by date of listing.</p>
      <p>
        Current live FDE roles count only live listings displayed on this site. A role counts when the title or description clearly maps to forward-deployed engineering, deployed engineering, AI deployment, applied AI customer engineering, or deeply technical solutions engineering.
      </p>
      <p>
        The tracker follows a stable source registry: {trackedCompanyNames}. Tier 1 ATS sources refresh automatically, and custom/manual sources are timestamped in <span class="mono">tracked-sources.json</span> with source URLs so they can be refreshed consistently.
      </p>
      <p>
        Weekly and monthly growth use stored snapshots in <span class="mono">history.json</span>. If an older snapshot does not exist yet, the comparison falls back to listing dates from current live roles; as snapshots accumulate, those become the baseline. Jobs are deduped by source URL where possible, otherwise by company, title, and primary location; expired roles are removed only after the configured absence window.
      </p>
      {lastSourceRefresh && <p class="mono micro">Source registry last observed {new Date(lastSourceRefresh).toLocaleDateString("en-GB", { day: "2-digit", month: "short", year: "numeric" })}</p>}
    </section>
  </main>
</BaseLayout>
