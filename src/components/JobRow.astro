---
import type { JobWithCompany } from "../lib/types";
import {
  describeLocations,
  formatComp,
  isClosingSoon,
  isNew,
  roleSignalLabel,
  postedAgo,
  stageLabel
} from "../lib/format";
import { leadSignupPath } from "../lib/leadCapture";
import { companyInitials, companyLogoUrl } from "../lib/logos";

type Props = {
  job: JobWithCompany;
};

const { job } = Astro.props;
const tags = job.company.industry_tags.slice(0, 2);
const overflow = job.company.industry_tags.length - tags.length;
const newlyPosted = isNew(job.posted_at);
const sourceLabels: Record<string, string> = {
  greenhouse: "Greenhouse",
  lever: "Lever",
  ashby: "Ashby",
  workday: "Workday",
  workable: "Workable",
  custom: "company careers",
  hn_who_is_hiring: "HN",
  manual: "manual review",
  indeed: "Indeed",
  wellfound: "Wellfound"
};
const sourceLabel = sourceLabels[job.source_provider] ?? job.source_provider;
const initials = companyInitials(job.company.name);
const logoUrl = companyLogoUrl(job.company);
---

<article class="job-row">
  <a class="job-row-link" href={job.apply_url} target="_blank" rel="noopener noreferrer" aria-label={`Apply for ${job.title} at ${job.company.name}`}>
    <div class="job-row-main">
      <div class="job-company-cell">
        <span class="company-logo" aria-hidden="true">
          <span class="company-logo-fallback">{initials}</span>
          {logoUrl && <img src={logoUrl} alt="" loading="lazy" onerror="this.style.display='none'" />}
        </span>
        <div class="job-company-line">
          <span class="job-company-name">{job.company.name}</span>
          <span class="chip stage">{stageLabel(job.company.stage)}</span>
          {job.is_featured && <span class="chip featured">Featured</span>}
        </div>
      </div>
      <div>
        <div class="job-title">{job.title}</div>
        <div class="job-meta-line">
          <span>{describeLocations(job)}</span>
          {job.travel_pct_band === "high_50_plus" && <span class="chip closing">50%+ travel</span>}
        </div>
      </div>
      <div class="job-tags">
        {tags.map((tag) => <span class="chip">{tag}</span>)}
        {overflow > 0 && <span class="chip">+{overflow}</span>}
        {isClosingSoon(job) && <span class="chip closing">Closing soon</span>}
      </div>
      <div class="job-right">
        <span class="job-comp">{formatComp(job)}</span>
        <span class="job-date-line">
          {newlyPosted && <span class="chip new">New</span>}
          <span class="job-date">{postedAgo(job.posted_at)}</span>
        </span>
      </div>
    </div>
  </a>
  <div class="job-hidden-line">
    <span>{roleSignalLabel(job)}</span>
    <span>·</span>
    <span>{job.benefits_tags.length ? job.benefits_tags.join(" · ") : "Benefits not listed"}</span>
    <span>·</span>
    <span>Source: {sourceLabel}</span>
    <span>·</span>
    <a class="job-referral-link" href={leadSignupPath}>Referral opportunities</a>
  </div>
</article>
