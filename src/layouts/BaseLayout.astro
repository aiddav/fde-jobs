---
import ThemeToggle from "../components/ThemeToggle";
import Ticker from "../components/Ticker.astro";
import "../styles/globals.css";
import { leadFormUrl } from "../lib/leadCapture";
import type { MarketStats, PostingStats, TickerItem } from "../lib/types";

type Props = {
  title?: string;
  description?: string;
  tickerItems?: TickerItem[];
  openRoleCount?: number;
  addedThisWeek?: number;
  marketStats?: MarketStats;
  postingStats?: PostingStats;
  ogImage?: string;
  showSurveyBanner?: boolean;
};

const {
  title = "FDE Jobs",
  description = "A dense jobs board for Forward Deployed Engineers, Deployed Engineers, Solutions Engineers, and AI Solutions Engineers.",
  tickerItems = [],
  openRoleCount = 0,
  addedThisWeek = 0,
  marketStats,
  postingStats,
  ogImage,
  showSurveyBanner = false
} = Astro.props;

const plausibleDomain = import.meta.env.PLAUSIBLE_DOMAIN;
const siteRoot = (Astro.site ?? new URL(import.meta.env.SITE_URL ?? "https://aiddav.github.io/fde-jobs")).toString();
const siteBase = siteRoot.endsWith("/") ? siteRoot : `${siteRoot}/`;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const baseHref = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const canonicalPath = Astro.url.pathname
  .replace(new RegExp(`^${basePath.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}/?`), "")
  .replace(/^\//, "");
const canonical = new URL(canonicalPath, siteBase).toString();
const pathWithoutBase = `/${canonicalPath}`;
const navItems = [
  { href: baseHref, label: "Jobs", active: canonicalPath === "" },
  { href: `${baseHref}content/`, label: "Content", active: pathWithoutBase.startsWith("/content") },
  { href: `${baseHref}growth/`, label: "Growth", active: pathWithoutBase.startsWith("/growth") }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <script is:inline>
      (() => {
        const match = document.cookie.match(/(?:^|; )theme=([^;]+)/);
        if (match) {
          document.documentElement.dataset.theme = decodeURIComponent(match[1]);
          return;
        }

        if (window.matchMedia("(max-width: 640px)").matches) {
          document.documentElement.dataset.theme = "dark";
        }
      })();
    </script>
    {
      plausibleDomain && (
        <script
          is:inline
          defer
          data-domain={plausibleDomain}
          src="https://plausible.io/js/script.js"
        />
      )
    }
  </head>
  <body>
    <Ticker items={tickerItems} openRoleCount={openRoleCount} addedThisWeek={addedThisWeek} marketStats={marketStats} postingStats={postingStats} />
    {
      showSurveyBanner && (
        <a
          class="survey-banner"
          href={leadFormUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="survey-banner-full">Access exclusive FDE jobs, referrals, founder intros, private events, and guides.</span>
          <span class="survey-banner-mobile">Sign up for exclusive FDE job offers and referrals. ↗</span>
        </a>
      )
    }
    <nav class="site-shell section-nav" aria-label="Primary sections">
      {navItems.map((item) => (
        <a href={item.href} aria-current={item.active ? "page" : undefined}>{item.label}</a>
      ))}
    </nav>
    <slot />
    <footer class="site-shell footer">
      <div class="footer-inner">
        <a class="footer-cta" href={leadFormUrl} target="_blank" rel="noopener noreferrer">Sign up for exclusive FDE offers</a>
        <ThemeToggle client:load />
      </div>
    </footer>
  </body>
</html>
